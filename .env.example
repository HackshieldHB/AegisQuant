# AegisQuant — Copy to .env and fill. Never commit .env.

# Mode: LIVE | PAPER | BACKTEST
AEGIS_MODE=PAPER
# Environment: LOCAL | VPS
AEGIS_ENVIRONMENT=LOCAL
# Required only for LIVE mode. Leave blank for PAPER/BACKTEST.
LIVE_TRADING_CONFIRM=

# Asset toggles (at least one True)
CRYPTO_ENABLED=True
FOREX_ENABLED=False
STOCKS_ENABLED=False

# Risk
MAX_RISK_PER_TRADE=0.02
MAX_PORTFOLIO_EXPOSURE=0.10
MAX_DAILY_DRAWDOWN=0.05
MAX_WEEKLY_DRAWDOWN=0.10
MAX_CONCURRENT_TRADES=5
MAX_SECTOR_EXPOSURE_PCT=0.40

# AI
AI_ENABLED=True
AI_CONFIDENCE_THRESHOLD=0.70
MODEL_ADMISSION_ENABLED=True
MODEL_MIN_TEST_ACCURACY=0.51
MODEL_MIN_WF_ACCURACY=0.51
MODEL_MIN_TRAIN_SAMPLES=1000
MODEL_CALIBRATION_METHOD=auto
LIVE_SYMBOLS=BTC/USDT,ETH/USDT,XRP/USDT,PEPE/USDT

# Shadow evaluation (never places orders)
SHADOW_EVALUATION_ENABLED=True
SHADOW_EVALUATION_SYMBOLS=BTC/USDT,ETH/USDT,XRP/USDT,PEPE/USDT
SHADOW_MIN_CONFIDENCE=0.55
SHADOW_MAX_CONFIDENCE=0.74
SHADOW_THRESHOLD_STEP=0.01
SHADOW_HORIZON_BARS=12
SHADOW_FEE_BPS=20
SHADOW_SLIPPAGE_BPS=10
SHADOW_SPREAD_BPS=2
SHADOW_MIN_DIRECTIONAL_MASS=0.50
SHADOW_MIN_SAMPLES=100

# Telegram
TELEGRAM_ENABLED=True
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROBABILITY_ALERT_INTERVAL_SEC=600

# Brokers (only for enabled assets)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=True

OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=True

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=True

# Logging
LOG_LEVEL=INFO

# Dashboard API (used by Dashboard/web on Vercel)
AEGIS_DASHBOARD_TOKEN=
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
MODEL_HEALTH_PROB_VAR=0.00005
MODEL_HEALTH_SIGNAL_WINDOW=400
MODEL_HEALTH_MIN_SIGNALS=2
MODEL_HEALTH_MAX_REJECT=0.95
